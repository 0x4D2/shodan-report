# Kopiere diese Datei nach .env und trage deine Werte ein.
# Die .env wird NICHT ins Repo committed.

# ── Pflichtfelder ────────────────────────────────────────────
# Shodan API Key (erforderlich)
SHODAN_API_KEY=your_shodan_api_key_here

# Ausgabeverzeichnis für Reports, Snapshots, Archive
# Leer lassen = aktuelles Arbeitsverzeichnis wird verwendet
OUTPUT_BASE_DIR=C:/Users/<username>/Documents/shodan-data

# ── NVD / CVE ────────────────────────────────────────────────
# NVD API Key (optional, erhöht Rate Limit)
NVD_API_KEY=your_nvd_api_key_here

# 1 = Live-Abfragen beim NVD, 0 = nur lokaler Cache
NVD_LIVE=0

# 1 = Fortschrittsanzeige bei NVD-Abfragen
NVD_PROGRESS=1

# 1 = NVD-Cache bei jedem Lauf neu laden
NVD_REFRESH=0

# ── HaveIBeenPwned ───────────────────────────────────────
# Optional. Ohne Key: Report zeigt manuelle Check-Links.
# Mit Key: automatische Prüfung der Standard- + Extra-Adressen.
# API-Key: https://haveibeenpwned.com/Subscription
HIBP_API_KEY=

# ── Debug ────────────────────────────────────────────────────
# 1 = Debug-Ausgaben für NVD/CISA Clients
DEBUG_CVE_CLIENTS=0

# 1 = Nur für lokale Entwicklung (erzwingt src/-Pfad)
USE_LOCAL_SRC=0

# ── E-Mail (optional) ────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_smtp_password
